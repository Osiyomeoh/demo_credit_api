# Server
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lendsqr_wallet

# Adjutor Karma API (sign up at https://app.adjutor.io)
ADJUTOR_API_KEY=your_adjutor_api_key_here
ADJUTOR_KARMA_BASE_URL=https://adjutor.lendsqr.com/v2/verification/karma

# Faux Auth (for development - use secure token in production)
FAUX_AUTH_SECRET=your_secret_key_for_token_generation
