{
  "name": "lendsqr-wallet-service",
  "version": "1.0.0",
  "description": "Demo Credit - MVP Wallet Service for Lendsqr Backend Engineering Assessment",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate:latest": "node -r ts-node/register ./node_modules/.bin/knex migrate:latest",
    "migrate:rollback": "node -r ts-node/register ./node_modules/.bin/knex migrate:rollback",
    "seed:run": "node -r ts-node/register ./node_modules/.bin/knex seed:run",
    "test": "jest --coverage --forceExit",
    "test:integration": "jest api.integration.test.ts --forceExit --runInBand",
    "test:watch": "jest --watch --forceExit",
    "karma:test": "ts-node src/scripts/testKarma.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "wallet",
    "lendsqr",
    "demo-credit"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "knex": "^3.1.0",
    "mysql2": "^3.6.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
